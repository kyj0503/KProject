
<main>
    {{>layouts/header}}

    <!-- 지도 영역 -->
    <div id="map" style="width: 1200px; height: 400px;"></div>

    <!-- 사진 업로드 섹션 -->
    <div class="upload-section">
        <button class="upload-btn">📷 흡연 구역 제보하기 </button>
        <input type="file" id="file-upload" accept="/image/*" style="display: none;">
    </div>

    {{>layouts/footer}}
</main>
<script src="http://dapi.kakao.com/v2/maps/sdk.js?appkey=d9719e3b0915cc617ce003f3e0681cb8"></script>
<script>
    // Kakao 지도 API 초기화
    document.addEventListener('DOMContentLoaded', function() {
        var mapContainer = document.getElementById('map'),
                mapOption = {
                    center: new kakao.maps.LatLng(37.5665, 126.9780),
                    level: 3
                };

        var map = new kakao.maps.Map(mapContainer, mapOption);

        // 마커 설정 (선택사항)
        var markerPosition  = new kakao.maps.LatLng(37.5665, 126.9780);
        var marker = new kakao.maps.Marker({
            position: markerPosition
        });
        marker.setMap(map);

        // 사진 업로드 버튼 동작 설정
        const uploadBtn = document.querySelector('.upload-btn');
        const fileInput = document.querySelector('#file-upload');

        uploadBtn.addEventListener('click', () => {
            fileInput.click(); // 파일 입력 클릭
        });

        // 메뉴 버튼 클릭 시 메뉴 보이기/숨기기
        const menuBtn = document.querySelector('.menu-btn');
        const menuList = document.querySelector('.menu-list');

        menuBtn.addEventListener('click', () => {
            menuList.style.display = menuList.style.display === 'none' || menuList.style.display === '' ? 'block' : 'none';
        });
    });
</script>



